# Puerto local del microservicio
PORT=3001

# Conexión a MySQL.
# Valores por defecto = contenedor del docker-compose.yml de la raíz (puerto 3307).
# Si usas un MySQL instalado localmente, normalmente será el puerto 3306.
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=admin123
DB_NAME=crud_personas
DB_POOL_SIZE=5
