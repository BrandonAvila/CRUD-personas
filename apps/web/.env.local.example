# URL base del microservicio (sin diagonal final).
# En local: la API de apps/api. En AWS: la URL del API Gateway.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Login con Amazon Cognito (opcional).
# Si se deja vacío, el frontend trabaja sin login (útil para la API local).
# Con la API desplegada en AWS, usa el output UserPoolClientId del stack SAM.
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1
